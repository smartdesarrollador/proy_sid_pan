@startuml Components-Architecture-Diagram
!theme plain
skinparam componentStyle rectangle
skinparam linetype ortho

title Sistema de Gestión de Roles, Permisos y Suscripciones\nDiagrama de Componentes - Arquitectura Dual Frontend

' ===============================================
' ESTILOS Y COLORES
' ===============================================

skinparam component {
    BackgroundColor<<frontend>> #E3F2FD
    BorderColor<<frontend>> #1976D2
    BackgroundColor<<frontend_admin>> #FFE0B2
    BorderColor<<frontend_admin>> #E65100
    BackgroundColor<<frontend_client>> #E1F5FE
    BorderColor<<frontend_client>> #0277BD
    BackgroundColor<<backend>> #F3E5F5
    BorderColor<<backend>> #7B1FA2
    BackgroundColor<<database>> #FFF3E0
    BorderColor<<database>> #F57C00
    BackgroundColor<<cache>> #E8F5E9
    BorderColor<<cache>> #388E3C
    BackgroundColor<<external>> #FCE4EC
    BorderColor<<external>> #C2185B
    BackgroundColor<<queue>> #FFF9C4
    BorderColor<<queue>> #F9A825
}

' ===============================================
' CAPA DE PRESENTACIÓN (DUAL FRONTEND)
' ===============================================

package "Frontend Admin\n(admin.plataforma.com)" <<frontend_admin>> {
    component "Angular Admin App" as AngularAdmin {
        component [Dashboard Admin] as DashboardAdmin
        component [User Management] as UserManagement
        component [Role Management] as RoleManagement
        component [Permission Management] as PermissionManagement
        component [Subscription Management] as SubscriptionManagement
        component [Audit Logs] as AuditLogsModule
        component [Settings] as SettingsModule

        component [Admin Auth Service] as AdminAuthService
        component [Admin API Service] as AdminApiService
        component [RBAC Service (Frontend)] as FrontendRBACService
    }

    component [Shared Guards\nAdmin] as AdminGuards
    component [Shared Interceptors\nAdmin] as AdminInterceptors
}

package "Frontend Cliente\n(app.plataforma.com)" <<frontend_client>> {
    component "Angular Client App" as AngularClient {
        component [Dashboard Usuario] as DashboardUsuario
        component [Calendario] as CalendarioModule
        component [Tareas] as TareasModule
        component [Notificaciones] as NotificacionesModule
        component [Archivos] as ArchivosModule
        component [Portafolio/Proyectos] as PortafolioModule
        component [Compartidos Conmigo] as CompartidosModule
        component [Perfil Usuario] as PerfilModule

        component [Client Auth Service] as ClientAuthService
        component [Client API Service] as ClientApiService
        component [Feature Gate Service] as FeatureGateService
    }

    component [Shared Guards\nClient] as ClientGuards
    component [Shared Interceptors\nClient] as ClientInterceptors
}

package "Shared Libraries" <<frontend>> {
    component [Tailwind CSS Config] as TailwindShared
    component [Common Components] as CommonComponents
    component [Common Models/Interfaces] as CommonModels
    component [RxJS Utils] as RxJSUtils
}

note right of AngularAdmin
  **Frontend Admin:**
  • URL: admin.plataforma.com
  • Usuarios: OrgAdmin, Manager (con permisos)
  • Módulos: RBAC, Billing, Audit
  • Tech: Angular 17+ Standalone
  • Tailwind CSS + Signals
end note

note right of AngularClient
  **Frontend Cliente:**
  • URL: app.plataforma.com
  • Usuarios: Todos (Member+)
  • Módulos: Servicios productivos
  • Tech: Angular 17+ Standalone
  • Feature gates por plan
end note

' ===============================================
' CAPA DE API (BACKEND)
' ===============================================

package "API Layer (Backend Unificado)" <<backend>> {
    component "Django REST Framework" as DRF {
        package "/api/v1/admin/" {
            component [Tenants API] as TenantsAPI
            component [Users API] as UsersAPI
            component [Roles API] as RolesAPI
            component [Permissions API] as PermissionsAPI
            component [Subscriptions API] as SubscriptionsAPI
            component [Audit Logs API] as AuditAPI
            component [Analytics API] as AnalyticsAPI
        }

        package "/api/v1/app/" {
            component [Calendar API] as CalendarAPI
            component [Tasks API] as TasksAPI
            component [Notifications API] as NotificationsAPI
            component [Files API] as FilesAPI
            component [Projects API] as ProjectsAPI
            component [Shares API] as SharesAPI
            component [Dashboard API] as DashboardAPI
        }

        package "/api/v1/auth/" {
            component [Login/Logout] as AuthAPI
            component [Register] as RegisterAPI
            component [Token Refresh] as TokenRefreshAPI
            component [Password Reset] as PasswordResetAPI
            component [MFA] as MFAAPI
        }

        component [Webhooks] as WebhooksAPI

        component [JWT Middleware] as JWTMiddleware
        component [Tenant Middleware] as TenantMiddleware
        component [Permission Middleware] as PermissionMiddleware
        component [Share Permission Middleware] as SharePermissionMiddleware
        component [Rate Limit Middleware] as RateLimitMiddleware
        component [Feature Gate Middleware] as FeatureGateMiddleware

        component [Auth Service] as BackendAuthService
        component [Billing Service] as BackendBillingService
        component [RBAC Service] as RBACService
        component [Notification Service] as NotificationService
        component [Calendar Service] as CalendarService
        component [Task Service] as TaskService
        component [File Service] as FileService
        component [Project Service] as ProjectService
        component [Share Service] as ShareService
        component [Permission Inheritance Engine] as PermissionInheritanceEngine
    }

    component [Django ORM] as ORM
    component [Django Signals] as Signals
    component [Serializers] as Serializers
}

note right of DRF
  **Tech Stack:**
  • Django 5.0+
  • Python 3.11+
  • DRF 3.14+
  • PyJWT
  • bcrypt

  **Patterns:**
  • ViewSets + Routers
  • Serializers con validación
  • Permissions personalizados
  • Signals para eventos
  • Middleware pipeline
end note

' ===============================================
' CAPA DE DATOS (DATABASE)
' ===============================================

package "Data Layer" <<database>> {
    database "PostgreSQL 15+" as PostgreSQL {
        component [Tables] as Tables
        component [Row-Level Security] as RLS
        component [Indexes] as Indexes
        component [Triggers] as Triggers
        component [Partitions] as Partitions
    }

    component [PgBouncer\nConnection Pool] as PgBouncer
    component [pg_stat_statements] as PgStats
}

note bottom of PostgreSQL
  **Features:**
  • Row-Level Security (RLS)
  • JSONB para settings/metadata
  • Full-text search (tsvector)
  • Partitioned tables (audit_log)
  • Composite indexes con tenant_id
  • Foreign keys + constraints

  **Performance:**
  • Connection pooling (10-50)
  • Read replicas (heavy queries)
  • Automatic VACUUM
  • Query optimization monitoring
end note

' ===============================================
' CAPA DE CACHE
' ===============================================

package "Cache Layer" <<cache>> {
    database "Redis 7+" as Redis {
        component [Session Store] as SessionStore
        component [Permissions Cache] as PermissionsCache
        component [Rate Limit Counters] as RateLimitCounters
        component [MFA Pending] as MFAPending
        component [Feature Flags Cache] as FeatureFlagsCache
    }
}

note bottom of Redis
  **Keys Structure:**
  • permissions:{user_id}:{tenant_id}
  • sessions:{session_id}
  • rate_limit:{ip}:{endpoint}
  • mfa_pending:{token}
  • features:{tenant_id}
  • lockout:{email}

  **TTLs:**
  • Permissions: 5 min
  • Sessions: 24 hours
  • Rate limits: 1 min
  • MFA pending: 5 min
  • Features: 5 min
end note

' ===============================================
' CAPA DE TAREAS ASÍNCRONAS
' ===============================================

package "Background Jobs" <<queue>> {
    component "Celery Workers" as Celery {
        component [Email Tasks] as EmailTasks
        component [Billing Tasks] as BillingTasks
        component [Notification Tasks] as NotificationTasks
        component [Cleanup Tasks] as CleanupTasks
        component [Export Tasks] as ExportTasks
    }

    component [Celery Beat\nScheduler] as CeleryBeat
    database "Redis\n(Broker)" as RedisBroker
}

note bottom of Celery
  **Tasks:**
  • send_email(template, data)
  • process_renewals() [daily]
  • retry_payment(tenant_id) [scheduled]
  • generate_invoice_pdf(invoice_id)
  • export_audit_logs(filters)
  • cleanup_expired_tokens() [daily]

  **Scheduling:**
  • Cron-like with Celery Beat
  • Task priority queues
  • Retry with exponential backoff
  • Result backend (Redis)
end note

' ===============================================
' SERVICIOS EXTERNOS
' ===============================================

package "External Services" <<external>> {
    component [Stripe API] as Stripe {
        portin "Charges" as StripeCharges
        portin "Customers" as StripeCustomers
        portin "Subscriptions" as StripeSubs
        portout "Webhooks" as StripeWebhooks
    }

    component [Email Service\n(SendGrid/SES)] as EmailService {
        portin "Send Email" as SendEmail
        portout "Webhooks" as EmailWebhooks
    }

    component [AWS S3] as S3 {
        portin "Upload" as S3Upload
        portin "Download" as S3Download
    }

    component [Monitoring\n(Sentry/DataDog)] as Monitoring {
        portin "Error Tracking" as ErrorTracking
        portin "Performance Metrics" as Metrics
    }
}

note bottom of Stripe
  **Integration:**
  • Stripe Elements (PCI-compliant)
  • Webhook signature verification
  • Idempotency keys
  • Customer portal

  **Events:**
  • invoice.payment_succeeded
  • invoice.payment_failed
  • customer.subscription.deleted
end note

' ===============================================
' INTERFACES Y PROTOCOLOS
' ===============================================

interface "HTTPS\nREST API" as HTTPS
interface "WebSocket\n(future)" as WebSocket
interface "PostgreSQL\nProtocol" as PostgresProtocol
interface "Redis\nProtocol" as RedisProtocol
interface "SMTP/API" as SMTP

