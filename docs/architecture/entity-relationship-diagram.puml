' ==============================================================================
' AUDIT & LOGGING ENTITIES
' ==============================================================================

entity "AuditLog" as audit_log <<Audit>> {
    PK(id, timestamp): BIGSERIAL, TIMESTAMP
    --
    FK(tenant_id): UUID
    FK(actor_user_id): UUID
    action: VARCHAR(50)
    resource_type: VARCHAR(50)
    resource_id: UUID
    --
    ip_address: INET
    user_agent: TEXT
    --
    timestamp: TIMESTAMP
}

note right of audit_log
    **Partitioned Table**
    - Range partitioning by timestamp (quarterly)
    - Partitions: audit_log_YYYY_qN
    - Example: audit_log_2026_q1, audit_log_2026_q2
    - Auto-creates future partitions
    - Drops partitions older than 7 years (retention)
end note

entity "AuditLogChange" as audit_log_change <<Audit>> {
    PK(id): UUID
    --
    FK(audit_log_id): BIGINT
    field_name: VARCHAR(100)
    old_value: TEXT
    new_value: TEXT
    data_type: VARCHAR(20)
    --
    created_at: TIMESTAMP
}

