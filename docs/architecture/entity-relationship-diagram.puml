' ==============================================================================
' RELATIONSHIPS - Core Multi-Tenancy
' ==============================================================================

tenant ||--o{ membership : "has members"
user ||--o{ membership : "belongs to tenants"
membership ||--o{ membership_role : "has roles"

' ==============================================================================
' RELATIONSHIPS - RBAC
' ==============================================================================

tenant ||--o{ role : "has"
role ||--o{ role : "inherits from (parent)"
