    description: TEXT
    is_system_role: BOOLEAN
    FK(parent_role_id): UUID
    --
    FK(created_by_id): UUID
    FK(updated_by_id): UUID
    created_at: TIMESTAMP
    updated_at: TIMESTAMP
    --
    UK(tenant_id, name)
}

entity "Permission" as permission <<RBAC>> {
    PK(id): UUID
    --
    UK(codename): VARCHAR(100)
    name: VARCHAR(255)
