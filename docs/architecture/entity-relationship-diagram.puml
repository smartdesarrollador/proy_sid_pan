    --
    FK(created_by_id): UUID
    FK(updated_by_id): UUID
    created_at: TIMESTAMP
    updated_at: TIMESTAMP
    --
    UK(role_id, permission_id, scope)
}

entity "MembershipRole" as membership_role <<RBAC>> {
    PK(id): UUID
    --
    FK(tenant_membership_id): UUID
    FK(role_id): UUID
    --
    created_at: TIMESTAMP
    --
    UK(tenant_membership_id, role_id)
}

entity "PermissionGroup" as permission_group <<RBAC>> {
