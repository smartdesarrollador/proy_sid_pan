@startuml RBAC-Subscription-System-Class-Diagram
!theme plain
skinparam classAttributeIconSize 0
skinparam linetype ortho

title Sistema de Gestión de Roles, Permisos y Suscripciones\nDiagrama de Clases - Modelo de Datos

' ===============================================
' ABSTRACT BASE MODELS
' ===============================================

abstract class TimestampedModel <<abstract>> {
  + created_at: DateTimeField
  + updated_at: DateTimeField
}

abstract class TenantAwareModel <<abstract>> {
  + tenant_id: UUID <<FK>>
  --
  + get_queryset(): QuerySet
}

abstract class AuditedModel <<abstract>> {
  + created_by_id: UUID <<FK>>
  + updated_by_id: UUID <<FK>>
}

' Herencias de modelos abstractos
TimestampedModel <|-- AuditedModel
TenantAwareModel --|> TimestampedModel

' ===============================================
' CORE MODELS - TENANT & USER
' ===============================================

class Tenant {
  + id: UUID <<PK>>
  + name: CharField(255)
  + subdomain: SlugField <<unique>>
  + logo: ImageField
  + primary_color: CharField(7)
  + settings: JSONField
  --
  # Subscription fields
  + subscription_plan: CharField(50)
  + subscription_status: CharField(20)
  + trial_ends_at: DateTimeField
  + subscription_current_period_end: DateTimeField
  + stripe_customer_id: CharField(255)
  --
  # Usage tracking
  + storage_used_bytes: BigIntegerField
  + api_calls_this_month: IntegerField
  --
  + is_trial_active(): bool
  + is_subscription_active(): bool
  + get_plan_limits(): dict
  + check_limit(resource: str): bool
}

class User {
  + id: UUID <<PK>>
  + email: EmailField <<unique>>
  + password: CharField(128)
  + first_name: CharField(150)
  + last_name: CharField(150)
  + is_active: BooleanField
  + is_staff: BooleanField
  + is_superuser: BooleanField
  + email_verified_at: DateTimeField
  + last_login: DateTimeField
  --
  # MFA fields
  + mfa_enabled: BooleanField
  + mfa_secret: CharField(32)
  --
  + get_full_name(): str
  + check_password(password: str): bool
  + set_password(password: str): void
  + has_perm(permission: str, tenant: Tenant): bool
  + get_roles(tenant: Tenant): QuerySet[Role]
}

class TenantMembership {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + user_id: UUID <<FK>>
  + is_active: BooleanField
  + invited_at: DateTimeField
  + joined_at: DateTimeField
  + invitation_token: CharField(255)
  + invitation_expires_at: DateTimeField
  --
  + is_invitation_valid(): bool
  + accept_invitation(): void
  + get_effective_permissions(): set[str]
}

' ===============================================
' RBAC MODELS - ROLES & PERMISSIONS
' ===============================================

class Role {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + name: CharField(100)
  + description: TextField
  + is_system_role: BooleanField
  + parent_role_id: UUID <<FK>>
  + color: CharField(7)
  + icon: CharField(50)
  --
  + get_all_permissions(): QuerySet[Permission]
  + get_inherited_permissions(): QuerySet[Permission]
  + has_permission(permission: str): bool
  + validate_inheritance(): bool
}

class Permission {
  + id: UUID <<PK>>
  + codename: CharField(100) <<unique>>
  + name: CharField(255)
  + resource: CharField(50)
  + action: CharField(50)
  + description: TextField
  + category: CharField(50)
  --
  + get_display_name(): str
  + parse_codename(): tuple[str, str]
}

class PermissionGrant {
  + id: UUID <<PK>>
  + role_id: UUID <<FK>>
  + permission_id: UUID <<FK>>
  + scope: CharField(20)
  + conditions: JSONField
  --
  + validate_scope(user: User, resource: Model): bool
  + get_filtered_queryset(qs: QuerySet): QuerySet
}

class PermissionGroup {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + name: CharField(100)
  + description: TextField
  + is_system_group: BooleanField
  --
  + get_permissions(): QuerySet[Permission]
}

class PermissionDelegation {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + delegator_id: UUID <<FK>>
  + delegatee_id: UUID <<FK>>
  + start_date: DateTimeField
  + end_date: DateTimeField
  + is_active: BooleanField
  --
  + is_valid(): bool
  + expire(): void
  + get_delegated_permissions(): QuerySet[Permission]
}

' ===============================================
' AUDIT & COMPLIANCE
' ===============================================

class AuditLog {
  + id: BigAutoField <<PK>>
  + timestamp: DateTimeField <<indexed>>
  + tenant_id: UUID <<FK>>
  + actor_user_id: UUID <<FK>>
  + action: CharField(50)
  + resource_type: CharField(50)
  + resource_id: UUID
  + changes: JSONField
  + ip_address: GenericIPAddressField
  + user_agent: TextField
  + session_id: UUID
  --
  + get_change_summary(): str
  + get_before_value(field: str): any
  + get_after_value(field: str): any
}

' ===============================================
' AUTHENTICATION & SESSIONS
' ===============================================

class RefreshToken {
  + id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + token: CharField(255) <<unique>>
  + expires_at: DateTimeField
  + created_at: DateTimeField
  + revoked_at: DateTimeField
  + device_info: JSONField
  --
  + is_valid(): bool
  + revoke(): void
  + rotate(): RefreshToken
}

class MFARecoveryCode {
  + id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + code: CharField(10) <<hashed>>
  + used_at: DateTimeField
  + created_at: DateTimeField
  --
  + is_used(): bool
  + verify(code: str): bool
}

class Session {
  + id: UUID <<PK>>
  + user_id: UUID <<FK>>
  + tenant_id: UUID <<FK>>
  + started_at: DateTimeField
  + last_activity_at: DateTimeField
  + expires_at: DateTimeField
  + ip_address: GenericIPAddressField
  + user_agent: TextField
  + device_type: CharField(50)
  + is_active: BooleanField
  --
  + is_expired(): bool
  + refresh(): void
  + terminate(): void
}

' ===============================================
' BILLING & SUBSCRIPTION
' ===============================================

class SubscriptionPlan {
  + id: UUID <<PK>>
  + name: CharField(50) <<unique>>
  + display_name: CharField(100)
  + description: TextField
  + price_monthly: DecimalField
  + price_annual: DecimalField
  + features: JSONField
  + limits: JSONField
  + is_active: BooleanField
  + sort_order: IntegerField
  --
  + get_features_list(): list[str]
  + has_feature(feature: str): bool
  + get_limit(resource: str): int
}

class Invoice {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + invoice_number: CharField(50) <<unique>>
  + status: CharField(20)
  + amount: DecimalField
  + currency: CharField(3)
  + period_start: DateField
  + period_end: DateField
  + issued_at: DateTimeField
  + paid_at: DateTimeField
  + stripe_invoice_id: CharField(255)
  + pdf_url: URLField
  --
  + generate_pdf(): str
  + send_email(): void
  + mark_as_paid(): void
}

class PaymentMethod {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + stripe_payment_method_id: CharField(255)
  + type: CharField(20)
  + card_brand: CharField(20)
  + card_last4: CharField(4)
  + card_exp_month: IntegerField
  + card_exp_year: IntegerField
  + is_default: BooleanField
  + created_at: DateTimeField
  --
  + is_expired(): bool
  + set_as_default(): void
}

class UsageTracking {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + date: DateField
  + metric_name: CharField(50)
  + value: BigIntegerField
  + metadata: JSONField
  --
  + get_monthly_total(metric: str): int
  + reset_monthly_counters(): void
}

' ===============================================
' NOTIFICATIONS
' ===============================================

class Notification {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + user_id: UUID <<FK>>
  + type: CharField(50)
  + title: CharField(255)
  + message: TextField
  + data: JSONField
  + is_read: BooleanField
  + read_at: DateTimeField
  + created_at: DateTimeField
  --
  + mark_as_read(): void
  + send_email(): void
}

class EmailLog {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + recipient: EmailField
  + subject: CharField(255)
  + template: CharField(100)
  + status: CharField(20)
  + sent_at: DateTimeField
  + error_message: TextField
  + metadata: JSONField
}

' ===============================================
' FEATURE FLAGS
' ===============================================

class FeatureFlag {
  + id: UUID <<PK>>
  + key: CharField(100) <<unique>>
  + name: CharField(255)
  + description: TextField
  + is_enabled_globally: BooleanField
  + rollout_percentage: IntegerField
  + required_plan: CharField(50)
  --
  + is_enabled_for_tenant(tenant: Tenant): bool
}

class TenantFeatureOverride {
  + id: UUID <<PK>>
  + tenant_id: UUID <<FK>>
  + feature_flag_id: UUID <<FK>>
  + is_enabled: BooleanField
  + enabled_at: DateTimeField
  + reason: TextField
}

' ===============================================
' RELATIONSHIPS - TENANT & USER
' ===============================================

Tenant "1" *-- "0..*" TenantMembership : contains
User "1" *-- "0..*" TenantMembership : member of
TenantMembership "0..*" o-- "0..*" Role : has roles
User "1" -- "0..*" RefreshToken : owns
User "1" -- "0..*" MFARecoveryCode : has codes
User "1" -- "0..*" Session : has sessions

' ===============================================
' RELATIONSHIPS - RBAC
' ===============================================

TenantAwareModel <|-- Role
AuditedModel <|-- Role
Role "0..1" <-- "0..*" Role : inherits from (parent)
Role "1" *-- "0..*" PermissionGrant : grants
Permission "1" -- "0..*" PermissionGrant : granted by
PermissionGroup "1" *-- "0..*" Permission : contains

TenantAwareModel <|-- PermissionGroup
AuditedModel <|-- PermissionGroup

TenantAwareModel <|-- PermissionDelegation
AuditedModel <|-- PermissionDelegation
User "1" -- "0..*" PermissionDelegation : delegates (delegator)
User "1" -- "0..*" PermissionDelegation : receives (delegatee)
PermissionDelegation "0..*" o-- "0..*" Permission : delegates

' ===============================================
' RELATIONSHIPS - AUDIT
' ===============================================

Tenant "1" -- "0..*" AuditLog : audits
User "0..1" -- "0..*" AuditLog : performs

' ===============================================
' RELATIONSHIPS - BILLING
' ===============================================

Tenant "1" -- "0..1" SubscriptionPlan : subscribed to
Tenant "1" *-- "0..*" Invoice : receives
Tenant "1" *-- "0..*" PaymentMethod : has methods
Tenant "1" *-- "0..*" UsageTracking : tracks usage

' ===============================================
' RELATIONSHIPS - NOTIFICATIONS
' ===============================================

TenantAwareModel <|-- Notification
Tenant "1" -- "0..*" Notification : receives
User "1" -- "0..*" Notification : receives
Tenant "1" -- "0..*" EmailLog : sent to

' ===============================================
' RELATIONSHIPS - FEATURE FLAGS
' ===============================================

FeatureFlag "1" -- "0..*" TenantFeatureOverride : overridden by
Tenant "1" -- "0..*" TenantFeatureOverride : overrides
SubscriptionPlan "1" -- "0..*" FeatureFlag : includes

' ===============================================
' ENUMERATIONS
' ===============================================

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
  SUSPENDED
}

enum SubscriptionPlanType {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum PermissionScope {
  ALL
  OWN
  DEPARTMENT
  TEAM
  CUSTOM
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  ASSIGN_ROLE
  REVOKE_ROLE
  GRANT_PERMISSION
  REVOKE_PERMISSION
  UPGRADE_PLAN
  DOWNGRADE_PLAN
  PAYMENT_SUCCESS
  PAYMENT_FAILED
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum NotificationType {
  ROLE_CHANGED
  TRIAL_ENDING
  PAYMENT_FAILED
  LIMIT_REACHED
  INVITATION_RECEIVED
  DELEGATION_GRANTED
}

' ===============================================
' ENUM RELATIONSHIPS
' ===============================================

Tenant ..> SubscriptionStatus : uses
Tenant ..> SubscriptionPlanType : uses
PermissionGrant ..> PermissionScope : uses
AuditLog ..> AuditAction : uses
Invoice ..> InvoiceStatus : uses
Notification ..> NotificationType : uses

' ===============================================
' NOTES
' ===============================================

note top of TenantAwareModel
  **Abstract Model**
  Todos los modelos multi-tenant
  heredan de esta clase base.
  Incluye tenant_id y manager
  personalizado que filtra
  automáticamente por tenant.
end note

note top of AuditedModel
  **Abstract Model**
  Tracking automático de
  quién creó/modificó el registro.
  Hereda de TimestampedModel.
end note

note right of Tenant
  **Core Entity**
  Representa una organización.
  Incluye info de suscripción
  integrada (no tabla separada).
  RLS enforcement a nivel DB.
end note

note right of Role
  **RBAC Core**
  Soporta herencia (parent_role).
  Roles de sistema (no editables)
  vs roles personalizados.
  Máximo 3 niveles de herencia.
end note

note bottom of PermissionGrant
  **Permisos Condicionales**
  Scope define contexto:
  - ALL: sin restricciones
  - OWN: solo recursos propios
  - DEPARTMENT: mismo departamento
  - CUSTOM: lógica personalizada
end note

note bottom of AuditLog
  **Compliance**
  Tabla inmutable (insert-only).
  Retención: 7 años.
  Particionada por mes.
  Índices compuestos con tenant_id.
end note

note left of SubscriptionPlan
  **Monetization**
  Features y límites definidos
  en JSONField para flexibilidad.
  Permite cambiar features sin
  migrations de DB.
end note

note bottom of UsageTracking
  **Metering**
  Tracking diario de:
  - Usuarios activos
  - Storage usado
  - API calls
  Reseteo mensual automático.
end note

legend right
  |= Símbolo |= Significado |
  | <<PK>> | Primary Key |
  | <<FK>> | Foreign Key |
  | <<unique>> | Unique constraint |
  | <<indexed>> | Database index |
  | <<abstract>> | Abstract model |
  | <<hashed>> | Hashed/encrypted |
  | --|> | Herencia |
  | *-- | Composición |
  | o-- | Agregación |
  | -- | Asociación |
  | ..> | Dependencia |

  **Tipos de Datos:**
  • UUID: Universal Unique Identifier
  • CharField(N): String con max length
  • TextField: String sin límite
  • BooleanField: True/False
  • DateTimeField: Fecha + hora
  • DateField: Solo fecha
  • IntegerField: Entero 32-bit
  • BigIntegerField: Entero 64-bit
  • DecimalField: Decimal preciso
  • JSONField: JSON object
  • EmailField: Email validado
  • URLField: URL validada
endlegend

@enduml
