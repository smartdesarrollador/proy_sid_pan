@startuml sequence-diagram-sharing
!theme plain

title Diagrama de Secuencia - Compartir Proyecto\ncon Herencia de Permisos

actor "Owner" as Owner
actor "Shared User\n(Alice)" as Alice
participant "API Gateway" as Gateway
participant "Django REST\nBackend" as API
participant "RBAC\nMiddleware" as RBAC
participant "Feature Gate\nService" as FeatureGate
database "PostgreSQL\n(RLS)" as DB
participant "Email Service" as Email
database "Redis\n(Cache)" as Redis

== 1. Compartir Proyecto ==

Owner -> Gateway : POST /api/v1/app/shares\n{resource_type: "project",\n resource_id: "{project_uuid}",\n shared_with_user_ids: ["{alice_uuid}"],\n permission_level: "editor",\n notify: true}
Gateway -> RBAC : Forward (authenticated)

RBAC -> RBAC : Verificar permiso\n'projects.share' in user.permissions
note right of RBAC
  Owner tiene todos los permisos
  sobre sus proyectos.
end note

RBAC -> API : Permiso concedido

== 2. Validar Feature Gate ==

API -> FeatureGate : checkLimit('shared_users',\n tenant, plan)
FeatureGate -> DB : SELECT COUNT(*) FROM shares\nWHERE tenant_id = ? AND resource_id = ?
DB --> FeatureGate : current_count: 8

FeatureGate -> FeatureGate : Verificar limite del plan\nProfessional: max 50 shared users

alt Limite excedido
  FeatureGate --> Owner : 402 Payment Required\n{error: "Upgrade to share with more users",\n upgrade_url: "/billing/upgrade"}
else Dentro del limite
  FeatureGate --> API : OK, dentro del limite
end

== 3. Crear Share y Cascada ==

API -> DB : BEGIN TRANSACTION

API -> DB : Verificar que Alice\npertenece al mismo tenant
DB --> API : OK, mismo tenant

API -> DB : INSERT INTO shares\n(resource_type='project',\n resource_id, shared_with=alice,\n permission_level='editor',\n is_inherited=false)
note right of DB
  Share principal (nivel Proyecto).
  is_inherited = false (share directo).
end note

== 4. Herencia Automatica ==

API -> DB : SELECT id FROM project_sections\nWHERE project_id = ?
DB --> API : sections: [sec_1, sec_2, sec_3]

loop Para cada seccion
  API -> DB : INSERT INTO shares\n(resource_type='section',\n resource_id=sec_N,\n shared_with=alice,\n permission_level='editor',\n is_inherited=true)

  API -> DB : SELECT id FROM project_items\nWHERE section_id = sec_N
  DB --> API : items: [item_1, item_2, ...]

  loop Para cada item
    API -> DB : INSERT INTO shares\n(resource_type='item',\n resource_id=item_N,\n shared_with=alice,\n permission_level='editor',\n is_inherited=true)
  end
end

note right of API
  Cascada completa:
  Project (editor, directo)
    -> Section 1 (editor, heredado)
       -> Item 1.1, 1.2 ... (editor, heredado)
    -> Section 2 (editor, heredado)
       -> Item 2.1, 2.2 ... (editor, heredado)
    -> Section 3 (editor, heredado)
       -> Item 3.1, 3.2 ... (editor, heredado)
end note

API -> DB : COMMIT

== 5. Notificacion y Audit ==

API -> Email : Enviar notificacion a Alice\n"Owner compartio 'Proyecto X' contigo\ncomo Editor"

API -> DB : INSERT INTO audit_logs\n(action='share.created',\n resource_type='project',\n resource_id, user_id=owner,\n changes={shared_with: alice,\n level: 'editor'})

API -> Redis : Invalidar cache\nde proyecto y permisos

API --> Owner : 201 Created\n{shares: [{id, shared_with: alice,\n permission_level: 'editor'}]}

== 6. Alice Accede al Proyecto ==

Alice -> Gateway : GET /api/v1/app/projects/{project_uuid}\nAuthorization: Bearer {alice_token}
Gateway -> RBAC : Forward

RBAC -> DB : SELECT permission_level FROM shares\nWHERE resource_type='project'\nAND resource_id=?\nAND shared_with=alice
DB --> RBAC : permission_level: 'editor'

RBAC -> API : Acceso concedido (editor)
API -> DB : SELECT * FROM projects\nWHERE id = ?
DB --> API : project data
API --> Alice : 200 OK\n{project: {id, name, sections: [...]}}

== 7. Override de Permiso Local ==

Owner -> Gateway : PATCH /api/v1/app/shares/{share_docs_id}\n{permission_level: "admin",\n is_inherited: false}
Gateway -> RBAC : Forward
RBAC -> API : Permiso concedido

API -> DB : UPDATE shares\nSET permission_level = 'admin',\n    is_inherited = false\nWHERE id = share_docs_id
note right of DB
  Seccion "Documentacion":
  Alice ahora es Admin (local).
  Icono visible en UI.
end note

API -> DB : INSERT INTO audit_logs\n(action='share.updated',\n changes={old: 'editor',\n new: 'admin', scope: 'local'})

API --> Owner : 200 OK\n{share: {permission_level: 'admin',\n is_inherited: false}}

== 8. Cambio en Padre: Propaga a Hijos ==

Owner -> Gateway : PATCH /api/v1/app/shares/{share_project_id}\n{permission_level: "viewer"}
Gateway -> API : Forward

API -> DB : UPDATE shares\nSET permission_level = 'viewer'\nWHERE id = share_project_id

API -> DB : UPDATE shares\nSET permission_level = 'viewer'\nWHERE resource_type IN ('section','item')\nAND shared_with = alice\nAND is_inherited = true
note right of DB
  Solo actualiza shares heredados.
  El override local en "Documentacion"
  (is_inherited=false) NO se modifica.

  Resultado final Alice:
  - Viewer en Credenciales (heredado)
  - Viewer en Config JWT (heredado)
  - Admin en Documentacion (local)
end note

API -> DB : INSERT INTO audit_logs\n(action='share.updated',\n changes={propagated: true,\n affected_children: N})

API --> Owner : 200 OK\n{share: {permission_level: 'viewer'},\n propagated_to: N}

@enduml
