@startuml component-diagram
!theme plain
skinparam componentStyle rectangle

title Diagrama de Componentes - Arquitectura del Sistema\nPlataforma SaaS Multi-Tenant

' === Frontend Layer ===
package "Frontend Layer" {
  component [Admin Panel\n---\nReact + Vite + TS\nshadcn/ui + Tailwind\nTanStack Query + Zustand\nReact Router v6\nadmin.plataforma.com] as AdminPanel

  component [Hub Client Portal\n---\nReact + Vite + TS\nTailwind CSS\nTanStack Query\nReact Router v6\nhub.plataforma.com\nDark mode + i18n ES/EN] as HubPortal

  component [Workspace App\n---\nReact + Vite + TS\nTailwind CSS\nFullCalendar, dnd-kit\nRecharts\napp.plataforma.com\n◄─── SSO desde Hub] as WorkspaceApp

  component [Digital Services\n---\nNext.js 14+ (SSR)\nApp Router\nnext-intl\nISR + Streaming\nplataforma.com/{svc}/{user}] as DigitalSSR

  component [Desktop App\n---\nTauri v2 (Rust + WebView)\nReact + Vite\nLocal sync + Offline\n◄─── SSO desde Hub] as DesktopApp
}

' === API Layer ===
package "API Gateway" {
  component [Nginx / AWS ALB\n---\nReverse Proxy\nSSL Termination\nLoad Balancing] as Gateway
}

package "Middleware" {
  component [JWT Auth\nMiddleware] as JWTAuth
  component [Tenant Isolation\nMiddleware] as TenantMW
  component [RBAC Enforcement\nMiddleware] as RBACMW
  component [Rate Limiting\nMiddleware] as RateLimitMW
}

package "Backend API (Django REST Framework)" {
  component [Auth Module\n---\n/api/v1/auth/\nLogin, Register\nMFA, Refresh\nPassword Reset] as AuthModule

  component [Admin Module\n---\n/api/v1/admin/\nTenants, Users\nRoles, Permissions\nAudit Logs] as AdminModule

  component [App Module\n---\n/api/v1/app/\nProjects, Tasks\nCalendar, Notes\nContacts, Bookmarks\nSnippets, Shares\nTeam management] as AppModule

  component [Digital Services Module\n---\n/api/v1/digital-services/\nProfiles, Cards\nLandings, Portfolio\nCV, Analytics] as DigitalModule

  component [Billing Module\n---\n/api/v1/billing/\nSubscriptions\nInvoices, Payments\nPromos, Feature Gates] as BillingModule

  component [Analytics Module\n---\n/api/v1/analytics/\nDashboards, KPIs\nReports, Export] as AnalyticsModule

  component [SSO Module\n---\n/api/v1/auth/sso/\nPOST sso/token/\nPOST sso/validate/\nTTL 60s, single-use\nAudit: sso.token_*] as SSOModule

  component [Hub & Services Module\n---\n/api/v1/app/services/\nService catalog\nTenant services\nReferral program\nHub notifications\nPayment methods] as HubModule

  component [Celery Workers\n---\nEmail sending\nBilling webhooks\nCache invalidation\nScheduled tasks] as CeleryWorkers
}

' === Data Layer ===
package "Data Layer" {
  database "PostgreSQL 15+\n---\nRow-Level Security\nMulti-tenant isolation\nPgBouncer pooling" as PostgreSQL

  database "Redis 7+\n---\nCache & Sessions\nRate limit counters\nCelery broker\nFeature flags" as Redis

  storage "S3 / MinIO\n---\nFile uploads\nAvatars, images\nPDF exports\nCDN origin" as S3
}

' === External Services ===
package "External Services" {
  component [Stripe\n---\nPayments\nSubscriptions\nWebhooks\nInvoicing] as Stripe

  component [SendGrid / SES\n---\nTransactional email\nVerification\nNotifications] as EmailService

  component [Google Calendar\n---\nCalDAV sync\nOAuth2 flow] as GoogleCal

  component [OAuth2 Providers\n---\nGoogle, GitHub\nMicrosoft SSO] as OAuth2

  component [Let's Encrypt\n---\nSSL certificates\nAuto-renewal\nCustom domains] as LetsEncrypt
}

' === Connections: Frontend -> Gateway ===
AdminPanel -down-> Gateway : HTTPS/REST
HubPortal -down-> Gateway : HTTPS/REST
WorkspaceApp -down-> Gateway : HTTPS/REST
DigitalSSR -down-> Gateway : HTTPS/REST\n(Server-side fetch)
DesktopApp -down-> Gateway : HTTPS/REST

' === Gateway -> Middleware -> Backend ===
Gateway -down-> JWTAuth
JWTAuth -down-> TenantMW
TenantMW -down-> RBACMW
RBACMW -down-> RateLimitMW

RateLimitMW -down-> AuthModule
RateLimitMW -down-> AdminModule
RateLimitMW -down-> AppModule
RateLimitMW -down-> DigitalModule
RateLimitMW -down-> BillingModule
RateLimitMW -down-> AnalyticsModule
RateLimitMW -down-> SSOModule
RateLimitMW -down-> HubModule

' === Backend -> Data ===
AuthModule -down-> PostgreSQL
AdminModule -down-> PostgreSQL
AppModule -down-> PostgreSQL
DigitalModule -down-> PostgreSQL
BillingModule -down-> PostgreSQL
AnalyticsModule -down-> PostgreSQL

AuthModule -down-> Redis
RateLimitMW -down-> Redis
AppModule -down-> S3
DigitalModule -down-> S3

SSOModule -down-> PostgreSQL
SSOModule -down-> Redis
HubModule -down-> PostgreSQL

CeleryWorkers -down-> Redis : broker
CeleryWorkers -down-> PostgreSQL

' === Backend -> External ===
BillingModule -right-> Stripe
CeleryWorkers -right-> EmailService
AppModule ..> GoogleCal
AuthModule ..> OAuth2
DigitalModule ..> LetsEncrypt

' === SSO validate: server-to-server ===
WorkspaceApp ..> SSOModule : server-to-server\nPOST sso/validate/
DesktopApp ..> SSOModule : server-to-server\nPOST sso/validate/

' === SSR specific ===
DigitalSSR -down-> Redis : ISR Cache

note right of Gateway
  Subdomain-based routing:
  hub.platform.com  -> Hub Client Portal
  admin.platform.com -> Admin Panel
  app.platform.com  -> Workspace App
  platform.com/{svc}/{user} -> Digital SSR
end note

note right of SSOModule
  SSO Flow:
  1. Hub POST /auth/sso/token/
  2. Hub redirects browser con sso_token
  3. Workspace POST /auth/sso/validate/
     (server-to-server, no CORS)
  4. Token invalidado en primer uso
end note

note bottom of TenantMW
  SET LOCAL app.tenant_id = '{uuid}'
  PostgreSQL RLS auto-filters
  all queries by tenant
end note

@enduml
